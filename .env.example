# Core
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fbif_rss?schema=public
SESSION_SECRET=please-change-to-long-random-string

# Feishu OAuth
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/feishu/callback
FEISHU_OAUTH_SCOPE=auth:user.id:read offline_access
FEISHU_ALLOWED_TENANT_KEY=

# Feishu alert (none|webhook|app)
FEISHU_ALERT_MODE=none
FEISHU_ALERT_WEBHOOK_URL=
FEISHU_ALERT_RECEIVE_ID=
FEISHU_ALERT_RECEIVE_ID_TYPE=open_id

# Bitable sync
BITABLE_BASE_URL=https://foodtalks.feishu.cn/base/RCs0bchlpaATPRsTxRbcZzL8nGc
BITABLE_APP_TOKEN=RCs0bchlpaATPRsTxRbcZzL8nGc
BITABLE_ITEM_TABLE_ID=
BITABLE_SOURCE_TABLE_ID=
BITABLE_ITEM_FIELD_TITLE=标题
BITABLE_ITEM_FIELD_SUMMARY=摘要
BITABLE_ITEM_FIELD_LINK=链接
BITABLE_ITEM_FIELD_SOURCE=来源
BITABLE_ITEM_FIELD_PUBLISHED_AT=发布时间
BITABLE_ITEM_FIELD_HASH=去重哈希
BITABLE_SOURCE_FIELD_NAME=名称
BITABLE_SOURCE_FIELD_URL=URL
BITABLE_SOURCE_FIELD_CATEGORY=分类
BITABLE_SOURCE_FIELD_ENABLED=启用
BITABLE_SOURCE_FIELD_TYPE=类型
BITABLE_SOURCE_FIELD_INTERVAL=轮询分钟
SOURCE_SYNC_ENABLED=false

# Scheduler
RSS_SCHEDULER_CRON=*/5 * * * *
SOURCE_SYNC_CRON=*/20 * * * *
RSS_FETCH_TIMEOUT_MS=12000
RSS_FETCH_CONCURRENCY=8
RSS_MAX_ITEMS_PER_FETCH=40
RSS_FAIL_THRESHOLD=3
